# GNN-MTL weights (download via scripts/bootstrap_gnn_mtl_model.py)
molmanager/resources/models/**/*.pt
!molmanager/resources/models/**/
!molmanager/resources/models/**/README.md
!molmanager/resources/models/**/.gitkeep

